<ApplicationDef>
	<Application>
		<Name>Scratch</Name>
		<Description>With Scratch, you can program your own interactive stories, games, and animations and share your creations with others in the online community.</Description>
		<Publisher>MIT Media Lab</Publisher>
		<AutoInstall>True</AutoInstall>
		<UserDocumentation>https://scratch.mit.edu/</UserDocumentation>
		<Icon>Scratch.png</Icon>
	</Application>
	<Downloads>
		<Download DeploymentType="DeploymentType1">
			<PrefetchScript>$URL = Get-InstallerURLfromWinget -apiUrl "https://api.github.com/repos/microsoft/winget-pkgs/contents/manifests/m/MITMediaLab/Scratch/3" -InstallerType exe -Architecture x86 -scope machine</PrefetchScript>
			<URL></URL>
			<DownloadFileName>ScratchInstaller.exe</DownloadFileName>
			<DownloadVersionCheck>
			$FullVersion = ([String](Get-ChildItem $DownloadFile | Get-ExtensionAttribute -ExtensionAttribute FileVersion).FileVersion).Trim()
			$Version = ([String](Get-ChildItem $DownloadFile | Get-ExtensionAttribute -ExtensionAttribute ProductVersion).ProductVersion).Trim()</DownloadVersionCheck>
			<Version></Version>
			<FullVersion></FullVersion>
			<AppRepoFolder></AppRepoFolder>
			<ExtraCopyFunctions></ExtraCopyFunctions>
		</Download>
	</Downloads>
	<DeploymentTypes>
		<DeploymentType Name="DeploymentType1">
			<DeploymentTypeName>Silently install Scratch</DeploymentTypeName>
			<InstallationType>Script</InstallationType>
			<Comments>Silent Installer for Scratch</Comments>
			<CacheContent>False</CacheContent>
			<BranchCache>True</BranchCache>
			<ContentFallback>True</ContentFallback>
			<OnSlowNetwork>Download</OnSlowNetwork>
			<InstallProgram>ScratchInstaller.exe /allusers /S</InstallProgram>
			<UninstallCmd>`"C:\Program Files (x86)\Scratch 3\Uninstall Scratch 3.exe`" /S</UninstallCmd>
			<InstallationBehaviorType>InstallForSystem</InstallationBehaviorType>
			<LogonReqType>WhetherOrNotUserLoggedOn</LogonReqType>
			<UserInteractionMode>Hidden</UserInteractionMode>
			<EstRuntimeMins>5</EstRuntimeMins>
			<MaxRuntimeMins>15</MaxRuntimeMins>
			<RebootBehavior>BasedOnExitCode</RebootBehavior>
			<DetectionMethodType>Custom</DetectionMethodType>
			<CustomDetectionMethods>
				<DetectionClause>
					<DetectionClauseType>File</DetectionClauseType>
					<Name>Scratch 3.exe</Name>
					<Path>C:\Program Files (x86)\Scratch 3</Path>
					<PropertyType>Version</PropertyType>
					<ExpectedValue>$FullVersion</ExpectedValue>
					<ExpressionOperator>GreaterEquals</ExpressionOperator>
					<Value>True</Value>
					<Is64Bit>True</Is64Bit>
				</DetectionClause>
			</CustomDetectionMethods>
		</DeploymentType>
	</DeploymentTypes>
		<Distribution>
			<DistributeContent>True</DistributeContent>
		</Distribution>
	<Supersedence>
		<Supersedence>True</Supersedence>
		<Uninstall>False</Uninstall>
		<CleanupSuperseded>True</CleanupSuperseded>
		<KeepSuperseded>2</KeepSuperseded>
	</Supersedence>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<DeploymentCollection>Scratch-Test</DeploymentCollection>
	</Deployment>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<AvailableOffset>7.00:00:00</AvailableOffset>
		<DeadlineOffset>14.00:00:00</DeadlineOffset>
		<DeploymentCollection>Scratch-Pilot</DeploymentCollection>
	</Deployment>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<AvailableOffset>14.00:00:00</AvailableOffset>
		<DeadlineOffset>28.00:00:00</DeadlineOffset>
		<DeploymentCollection>Scratch-General Availability</DeploymentCollection>
	</Deployment>
</ApplicationDef>
