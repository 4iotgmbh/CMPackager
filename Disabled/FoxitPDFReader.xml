<ApplicationDef>
	<Application>
		<Name>Foxit PDF Reader</Name>
		<Description>Foxit is a powerful PDF reader for viewing, filling out forms and more</Description>
		<Publisher>Foxit Software Inc.</Publisher>
		<AutoInstall>True</AutoInstall>
		<Icon>FoxitReader.png</Icon>
	</Application>
	<Downloads>
		<Download DeploymentType="DeploymentType1">
			<PrefetchScript>$URL = Get-InstallerURLfromWinget -apiUrl "https://api.github.com/repos/microsoft/winget-pkgs/contents/manifests/f/Foxit/FoxitReader" -InstallerType exe -Architecture x64</PrefetchScript>
			<URL></URL>
			<DownloadFileName>foxitreader.exe</DownloadFileName>
			<Version></Version>
			<FullVersion></FullVersion>
			<DownloadVersionCheck>$Version = (Get-item $TempDir\$DownloadFileName).VersionInfo.FileVersion</DownloadVersionCheck>
			<ExtraCopyFunctions>
					start-process "$TempDir\$DownloadFileName" -ArgumentList "/extract $TempDir\FoxitReaderTemp /quiet" -wait
					copy-item "$TempDir\FoxitReaderTemp\*" -Destination "$DestinationPath" -Force -recurse
			</ExtraCopyFunctions>
		</Download>
	</Downloads>
	<DeploymentTypes>
		<DeploymentType Name="DeploymentType1">
			<DeploymentTypeName>Foxit Silent Install</DeploymentTypeName>
			<InstallationType>MSI</InstallationType>
			<Comments>Silent Installer for Foxit PDF Reader</Comments>
			<Language>English</Language>
			<CacheContent>False</CacheContent>
			<BranchCache>True</BranchCache>
			<ContentFallback>True</ContentFallback>
			<OnSlowNetwork>Download</OnSlowNetwork>
			<InstallationMSI>Setup.msi</InstallationMSI>
			<UninstallCmd></UninstallCmd>
			<Force32bit>False</Force32bit>
			<InstallationBehaviorType>InstallForSystem</InstallationBehaviorType>
			<LogonReqType>WhetherOrNotUserLoggedOn</LogonReqType>
			<UserInteractionMode>Hidden</UserInteractionMode>
			<ReqUserInteraction>False</ReqUserInteraction>
			<EstRuntimeMins>5</EstRuntimeMins>
			<MaxRuntimeMins>15</MaxRuntimeMins>
			<RebootBehavior>BasedOnExitCode</RebootBehavior>
			<DetectionMethodType>MSI</DetectionMethodType>
		</DeploymentType>
	</DeploymentTypes>
	<Distribution>
		<DistributeContent>True</DistributeContent>
	</Distribution>
	<Supersedence>
		<Supersedence>True</Supersedence>
		<Uninstall>False</Uninstall>
		<CleanupSuperseded>True</CleanupSuperseded>
		<KeepSuperseded>2</KeepSuperseded>
	</Supersedence>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<DeploymentCollection>Foxit PDF Reader-Test</DeploymentCollection>
	</Deployment>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<AvailableOffset>7.00:00:00</AvailableOffset>
		<DeadlineOffset>14.00:00:00</DeadlineOffset>
		<DeploymentCollection>Foxit PDF Reader-Pilot</DeploymentCollection>
	</Deployment>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<AvailableOffset>14.00:00:00</AvailableOffset>
		<DeadlineOffset>28.00:00:00</DeadlineOffset>
		<DeploymentCollection>Foxit PDF Reader-General Availability</DeploymentCollection>
	</Deployment>
</ApplicationDef>