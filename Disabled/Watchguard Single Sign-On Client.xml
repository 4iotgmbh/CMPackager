<ApplicationDef>
	<Application>
		<Name>Watchguard Single Sign-On Client</Name>
		<Description>Watchguard Single Sign-On Client</Description>
		<Publisher>Watchguard</Publisher>
		<AutoInstall>True</AutoInstall>
		<Icon>watchguard_sso_client.png</Icon>
	</Application>
	<Downloads>
		<Download DeploymentType="DeploymentType1">
			<PrefetchScript>$URL = Get-InstallerURLfromWinget -apiUrl "https://api.github.com/repos/microsoft/winget-pkgs/contents/manifests/w/WatchGuard/WatchGuardAuthenticationClient" -InstallerType msi</PrefetchScript>
			<URL></URL>
			<DownloadFileName>WG-Authentication-Client.msi</DownloadFileName>
			<Version></Version>
			<FullVersion></FullVersion>
			<DownloadVersionCheck>[String]$Version = ([String](Get-MSIInfo -Path $DownloadFile -Property ProductVersion)).TrimStart().TrimEnd()</DownloadVersionCheck>
			<ExtraCopyFunctions></ExtraCopyFunctions>
		</Download>
	</Downloads>
	<DeploymentTypes>
		<DeploymentType Name="DeploymentType1">
			<DeploymentTypeName>Watchguard Single Sign-On Client Silent Install</DeploymentTypeName>
			<InstallationType>MSI</InstallationType>
			<Comments>Silent Installer for Watchguard SSO Client</Comments>
			<Language>English</Language>
			<CacheContent>False</CacheContent>
			<BranchCache>True</BranchCache>
			<ContentFallback>True</ContentFallback>
			<OnSlowNetwork>Download</OnSlowNetwork>
			<InstallationMSI>WG-Authentication-Client.msi</InstallationMSI>
			<UninstallCmd></UninstallCmd>
			<Force32bit>False</Force32bit>
			<InstallationBehaviorType>InstallForSystem</InstallationBehaviorType>
			<LogonReqType>WhetherOrNotUserLoggedOn</LogonReqType>
			<UserInteractionMode>Hidden</UserInteractionMode>
			<ReqUserInteraction>False</ReqUserInteraction>
			<EstRuntimeMins>5</EstRuntimeMins>
			<MaxRuntimeMins>15</MaxRuntimeMins>
			<RebootBehavior>BasedOnExitCode</RebootBehavior>
			<DetectionMethodType>MSI</DetectionMethodType>
		</DeploymentType>
	</DeploymentTypes>
	<Distribution>
		<DistributeContent>True</DistributeContent>
	</Distribution>
	<Supersedence>
		<Supersedence>True</Supersedence>
		<Uninstall>False</Uninstall>
		<CleanupSuperseded>True</CleanupSuperseded>
		<KeepSuperseded>2</KeepSuperseded>
	</Supersedence>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<AvailableOffset>0.00:00:00</AvailableOffset>
		<DeadlineOffset>0.00:00:00</DeadlineOffset>
		<DeploymentCollection>Watchguard Single Sign-On Client-Test</DeploymentCollection>
	</Deployment>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<AvailableOffset>7.00:00:00</AvailableOffset>
		<DeadlineOffset>14.00:00:00</DeadlineOffset>
		<DeploymentCollection>Watchguard Single Sign-On Client-Pilot</DeploymentCollection>
	</Deployment>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<AvailableOffset>14.00:00:00</AvailableOffset>
		<DeadlineOffset>28.00:00:00</DeadlineOffset>
		<DeploymentCollection>Watchguard Single Sign-On Client-General Availability</DeploymentCollection>
	</Deployment>
</ApplicationDef>
