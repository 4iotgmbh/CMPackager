<ApplicationDef>
	<Application>
		<Name>Fusion 360</Name>
		<Description>Fusion 360 helps students and educators prepare for the future of design. It's the first 3D CAD, CAM, and CAE tool of its kind, connecting your entire product development process into one cloud-based platform. Download the software today, then turn your ideas into reality.</Description>
		<Publisher>Autodesk</Publisher>
		<AutoInstall>True</AutoInstall>
		<UserDocumentation>https://www.autodesk.com/products/fusion-360/overview</UserDocumentation>
		<Icon>Fusion360.ico</Icon>
	</Application>
	<Downloads>
		<Download DeploymentType="DeploymentType1">
			<PrefetchScript>$URL = Get-InstallerURLfromWinget -apiUrl "https://api.github.com/repos/microsoft/winget-pkgs/contents/manifests/a/Autodesk/Fusion360" -InstallerType exe -Architecture x64</PrefetchScript>
			<URL></URL>
			<DownloadFileName>Fusion 360 Admin Install.exe</DownloadFileName>
			<DownloadVersionCheck>$Version = [String]((Get-Item $TempDir\$DownloadFileName).VersionInfo.ProductMinorPart) + '.' + [String]((Get-Item $TempDir\$DownloadFileName).VersionInfo.ProductBuildPart) + '.' + [String]((Get-Item $TempDir\$DownloadFileName).VersionInfo.ProductMajorPart)</DownloadVersionCheck>
			<FullVersion></FullVersion>
			<Version></Version>
            <ExtraCopyFunctions>copy-item $ScriptRoot\ExtraFiles\Fusion360\install.ps1 -Destination $DestinationPath\install.ps1 -Force -EA SilentlyContinue</ExtraCopyFunctions>
		</Download>
	</Downloads>
	<DeploymentTypes>
		<DeploymentType Name="DeploymentType1">
			<DeploymentTypeName>AutoDesk Fusion 360 Lab Silent Installer</DeploymentTypeName>
			<InstallationType>Script</InstallationType>
			<CacheContent>False</CacheContent>
			<ContentFallback>True</ContentFallback>
			<OnSlowNetwork>Download</OnSlowNetwork>
			<InstallProgram>powershell -executionpolicy bypass .\install.ps1</InstallProgram>
			<UninstallCmd>`"Fusion 360 Admin Install.exe`" --process uninstall --quiet</UninstallCmd>
			<InstallationBehaviorType>InstallForSystem</InstallationBehaviorType>
			<LogonReqType>WhetherOrNotUserLoggedOn</LogonReqType>
			<UserInteractionMode>Hidden</UserInteractionMode>
			<EstRuntimeMins>10</EstRuntimeMins>
			<MaxRuntimeMins>25</MaxRuntimeMins>
			<RebootBehavior>BasedOnExitCode</RebootBehavior>
            <DetectionMethodType>CustomScript</DetectionMethodType>
            <ScriptLanguage>PowerShell</ScriptLanguage>
            <DetectionMethod>[version]$InstalledVersion = ((Get-Content "C:\Program Files\AutoDesk\Fusion360.json" -EA SilentlyContinue) | ConvertFrom-Json -ea SilentlyContinue).manifest."build-version";
if (($InstalledVersion -ge "$Version") -and (get-item "C:\Program Files\Autodesk\webdeploy\production\*\Fusion360.exe" -EA SilentlyContinue)){Write-Output "Installed"}</DetectionMethod>
		</DeploymentType>
	</DeploymentTypes>
	<Distribution>
		<DistributeContent>True</DistributeContent>
	</Distribution>
	<Supersedence>
		<Supersedence>True</Supersedence>
		<Uninstall>False</Uninstall>
		<CleanupSuperseded>True</CleanupSuperseded>
		<KeepSuperseded>2</KeepSuperseded>
	</Supersedence>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<AvailableOffset>0.00:00:00</AvailableOffset>
		<DeadlineOffset>0.00:00:00</DeadlineOffset>
		<DeploymentCollection>Fusion 360-Test</DeploymentCollection>
	</Deployment>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<AvailableOffset>7.00:00:00</AvailableOffset>
		<DeadlineOffset>14.00:00:00</DeadlineOffset>
		<DeploymentCollection>Fusion 360-Pilot</DeploymentCollection>
	</Deployment>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<AvailableOffset>14.00:00:00</AvailableOffset>
		<DeadlineOffset>28.00:00:00</DeadlineOffset>
		<DeploymentCollection>Fusion 360-General Availability</DeploymentCollection>
	</Deployment>
</ApplicationDef>