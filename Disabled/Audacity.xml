<ApplicationDef>
	<Application>
		<Name>Audacity</Name>
		<Description></Description>
		<Publisher>audacityteam</Publisher>
		<AutoInstall>True</AutoInstall>
		<UserDocumentation>https://www.audacityteam.org/</UserDocumentation>
		<Icon>Audacity.png</Icon>
	</Application>
	<Downloads>
		<Download DeploymentType="DeploymentType1">
						<PrefetchScript>$URL = Get-InstallerURLfromWinget -apiUrl "https://api.github.com/repos/microsoft/winget-pkgs/contents/manifests/a/Audacity/Audacity" -InstallerType exe -Architecture x64</PrefetchScript>
			<URL></URL>
			<DownloadFileName>Audacity.exe</DownloadFileName>
			<Version></Version>
			<FullVersion></FullVersion>
			<DownloadVersionCheck>
			$FullVersion = (Get-ItemProperty $DownloadFile).VersionInfo.FileVersion.TrimStart().TrimEnd()
			$Version = ($FullVersion).Replace(".0","").TrimStart().TrimEnd()
			</DownloadVersionCheck>
			<ExtraCopyFunctions></ExtraCopyFunctions>
		</Download>
	</Downloads>
	<DeploymentTypes>
		<DeploymentType Name="DeploymentType1">
			<DeploymentTypeName>Audacity Installer</DeploymentTypeName>
			<InstallationType>Script</InstallationType>
			<CacheContent>False</CacheContent>
			<BranchCache>True</BranchCache>
			<ContentFallback>True</ContentFallback>
			<OnSlowNetwork>Download</OnSlowNetwork>
			<InstallProgram>Audacity.exe /VERYSILENT /NORESTART</InstallProgram>
			<UninstallCmd></UninstallCmd>
			<InstallationBehaviorType>InstallForSystem</InstallationBehaviorType>
			<LogonReqType>WhetherOrNotUserLoggedOn</LogonReqType>
			<UserInteractionMode>Hidden</UserInteractionMode>
			<EstRuntimeMins>15</EstRuntimeMins>
			<MaxRuntimeMins>60</MaxRuntimeMins>
			<RebootBehavior>BasedOnExitCode</RebootBehavior>
			<DetectionMethodType>Custom</DetectionMethodType>
			<CustomDetectionMethods>
				<DetectionClause>
					<DetectionClauseType>File</DetectionClauseType>
					<Name>Audacity.exe</Name>
					<Path>%ProgramFiles%\Audacity\</Path>
					<PropertyType>Version</PropertyType>
					<ExpectedValue>$FullVersion</ExpectedValue>
					<ExpressionOperator>GreaterEquals</ExpressionOperator>
					<Value>True</Value>
				</DetectionClause>
			</CustomDetectionMethods>
		</DeploymentType>
	</DeploymentTypes>
	<Distribution>
		<DistributeContent>True</DistributeContent>
	</Distribution>
	<Supersedence>
		<Supersedence>True</Supersedence>
		<Uninstall>False</Uninstall>
		<CleanupSuperseded>True</CleanupSuperseded>
		<KeepSuperseded>2</KeepSuperseded>
	</Supersedence>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<DeploymentCollection>Audacity-Test</DeploymentCollection>
	</Deployment>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<AvailableOffset>7.00:00:00</AvailableOffset>
		<DeadlineOffset>14.00:00:00</DeadlineOffset>
		<DeploymentCollection>Audacity-Pilot</DeploymentCollection>
	</Deployment>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<AvailableOffset>14.00:00:00</AvailableOffset>
		<DeadlineOffset>28.00:00:00</DeadlineOffset>
		<DeploymentCollection>Audacity-General Availability</DeploymentCollection>
	</Deployment>
</ApplicationDef>
