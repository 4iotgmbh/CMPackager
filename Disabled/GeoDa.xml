<ApplicationDef>
	<Application>
		<Name>GeoDa</Name>
		<Description>GeoDa is a free and open source software tool that serves as an introduction to spatial data analysis. It is designed to facilitate new insights from data analysis by exploring and modeling spatial patterns.</Description>
		<Publisher>GeoDa Team</Publisher>
		<AutoInstall>True</AutoInstall>
		<UserDocumentation>https://geodacenter.github.io/</UserDocumentation>
		<Icon>GeoDa.ico</Icon>
	</Application>
	<Downloads>
		<Download DeploymentType="DeploymentType1">
			<PrefetchScript>
					$URL = $(Get-InstallerURLfromWinget -apiUrl "https://api.github.com/repos/microsoft/winget-pkgs/contents/manifests/g/GeoDa/GeoDa" -InstallerType zip -Architecture x64).Url
				</PrefetchScript>
			<URL></URL>
			<DownloadFileName>GeoDa-Windows-64bit.zip</DownloadFileName>
			<Version></Version>
			<FullVersion></FullVersion>
			<DownloadVersionCheck>
					&amp; $ScriptRoot\7za.exe x "$TempDir\GeoDa-Windows-64bit.zip" -o"$TempDir\GeoDaTemp" -y
					$Version = ((Get-item $TempDir\GeoDaTemp\*.exe).VersionInfo.ProductVersion).TrimStart().TrimEnd()
			</DownloadVersionCheck>
			<ExtraCopyFunctions>
					ren $(ls $tempDir\GeoDaTemp\GeoDa*.exe) GeoDa-Windows-64bit.exe
					Copy-Item $TempDir\GeoDaTemp\*.exe -Destination $DestinationPath -Force -Recurse
		</ExtraCopyFunctions>
		</Download>
	</Downloads>
	<DeploymentTypes>
		<DeploymentType Name="DeploymentType1">
			<DeploymentTypeName>GeoDa Silent Install</DeploymentTypeName>
			<InstallationType>Script</InstallationType>
			<CacheContent>False</CacheContent>
			<BranchCache>True</BranchCache>
			<ContentFallback>True</ContentFallback>
			<OnSlowNetwork>Download</OnSlowNetwork>
			<InstallProgram>GeoDa-Windows-64bit.exe /VerySilent</InstallProgram>
			<UninstallCmd>`"%ProgramFiles%\GeoDa Software\unins000.exe`" /SILENT</UninstallCmd>
			<InstallationBehaviorType>InstallForSystem</InstallationBehaviorType>
			<LogonReqType>WhetherOrNotUserLoggedOn</LogonReqType>
			<UserInteractionMode>Hidden</UserInteractionMode>
			<EstRuntimeMins>10</EstRuntimeMins>
			<MaxRuntimeMins>40</MaxRuntimeMins>
			<RebootBehavior>BasedOnExitCode</RebootBehavior>
			<DetectionMethodType>Custom</DetectionMethodType>
			<CustomDetectionMethods>
				<DetectionClause>
					<DetectionClauseType>RegistryKeyValue</DetectionClauseType>
					<Hive>LocalMachine</Hive>
					<KeyName>SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\GeoDa_is1</KeyName>
					<ValueName>DisplayVersion</ValueName>
					<PropertyType>Version</PropertyType>
					<ExpressionOperator>IsEquals</ExpressionOperator>
					<ExpectedValue>$Version</ExpectedValue>
					<Value>True</Value>
				</DetectionClause>
			</CustomDetectionMethods>
		</DeploymentType>
	</DeploymentTypes>
	<Distribution>
		<DistributeContent>True</DistributeContent>
	</Distribution>
	<Supersedence>
		<Supersedence>True</Supersedence>
		<Uninstall>False</Uninstall>
		<CleanupSuperseded>True</CleanupSuperseded>
		<KeepSuperseded>2</KeepSuperseded>
	</Supersedence>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<AvailableOffset>0.00:00:00</AvailableOffset>
		<DeadlineOffset>0.00:00:00</DeadlineOffset>
		<DeploymentCollection>GeoDa-Test</DeploymentCollection>
	</Deployment>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<AvailableOffset>7.00:00:00</AvailableOffset>
		<DeadlineOffset>14.00:00:00</DeadlineOffset>
		<DeploymentCollection>GeoDa-Pilot</DeploymentCollection>
	</Deployment>
	<Deployment>
		<DeploySoftware>True</DeploySoftware>
		<Purpose>Required</Purpose>
		<AvailableOffset>14.00:00:00</AvailableOffset>
		<DeadlineOffset>28.00:00:00</DeadlineOffset>
		<DeploymentCollection>GeoDa-General Availability</DeploymentCollection>
	</Deployment>
</ApplicationDef>